<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:flowable="http://flowable.org/bpmn"
             targetNamespace="test">

    <process id="failingServiceTask" name="Failing Service Task Process" isExecutable="true">
        <startEvent id="startEvent" name="Start"/>
        <serviceTask id="serviceTask" name="Failing Service Task"
                     flowable:expression="${UnableToResolveExpression}"
                     flowable:async="true"
                     flowable:exclusive="true">
            <extensionElements>
                <flowable:failedJobRetryTimeCycle>${failedJobRetryTimeCycle}</flowable:failedJobRetryTimeCycle>
            </extensionElements>
        </serviceTask>
        <endEvent id="endEvent" name="End"/>
        <sequenceFlow id="flow1" sourceRef="startEvent" targetRef="serviceTask"/>
        <sequenceFlow id="flow2" sourceRef="serviceTask" targetRef="endEvent"/>
    </process>
</definitions>