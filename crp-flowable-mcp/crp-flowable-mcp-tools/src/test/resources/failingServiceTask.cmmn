<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/CMMN/20151109/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:flowable="http://flowable.org/cmmn" xmlns:cmmndi="http://www.omg.org/spec/CMMN/20151109/CMMNDI" xmlns:dc="http://www.omg.org/spec/CMMN/20151109/DC" xmlns:di="http://www.omg.org/spec/CMMN/20151109/DI" targetNamespace="http://www.flowable.org/casedef">
    <case id="failingServiceTask" name="failingServiceTask" flowable:initiatorVariableName="initiator">
        <casePlanModel id="casePlanModel">
            <planItem id="planItem2" name="Async service task" definitionRef="asyncServiceTask"/>
            <task id="asyncServiceTask" name="Async service task" isBlocking="false" flowable:async="true" flowable:type="java" flowable:delegateExpression="${failing}"/>
        </casePlanModel>
    </case>
</definitions>