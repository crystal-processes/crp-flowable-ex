<?xml version="1.0" encoding="UTF-8"?>
<definitions
        xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
        targetNamespace="test" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns:flowable="http://flowable.org/bpmn"
        xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL ">

    <process id="oneAiTaskProcess">
        <startEvent id="theStart">
            <extensionElements>
                <flowable:executionListener event="end" delegateExpression="${aiAutomationDelegate}">
                    <extensionElements>
                        <flowable:field name="user" expression="Hello World"/>
                        <flowable:field name="chatClient" expression="${chatClient}"/>
                        <flowable:field name="dynamicBpmnService" expression="${dynamicBpmnService}"/>
                    </extensionElements>
                </flowable:executionListener>
            </extensionElements>
        </startEvent>


    </process>

</definitions>
